# =============================================================================
# GenAI-Chat — environment configuration
# =============================================================================
# Copy this file to `.env` at the project root and fill in real values.
# Loaded by:
#   - docker-compose (backend container)        — env_file: .env
#   - data_indexing/data_indexing.py            — load_dotenv from project root
# -----------------------------------------------------------------------------

# --- Required ----------------------------------------------------------------

# OpenAI Keys
OPENAI_API_KEY=

# HuggingFace Token
HF_TOKEN=

# --- Optional: vector index tuning --------------
# Vector index type. Must match between backend and data_indexing.
# FLAT  — exact KNN, best for < 1M vectors when accuracy matters most.
# HNSW  — approximate, best for larger corpora when speed matters most.
INDEX_TYPE=HNSW

# HNSW query-time candidate pool. Must be >= VECTOR_TOP_K (see backend/config.py).
# Default 64 is sized for VECTOR_TOP_K=20.
EF_RUNTIME=64

# --- Optional: Azure Blob Storage indexing source ----------------------------
AZURE_STORAGE_CONNECTION_STRING=

# --- Optional: AWS S3 indexing source ----------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
